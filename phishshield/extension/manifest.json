{
  "manifest_version": 3,
  "name": "PhishShield Auto-Block",
  "version": "1.1",
  "description": "Detects phishing websites in real-time, displays popup warnings, and auto-blocks malicious pages.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}